<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("temp/head", { title: "CodeType | " + viewedUsername }) %>
    
    <style>
        .prof-cont {
            padding: 32px;
            max-width: 800px;
            margin: 0 auto;
        }

        .prof-header {
            display: flex;
            gap: 32px;
            align-items: center;
            margin-bottom: 48px;
        }

        .prof-avatar {
            width: 120px;
            height: 120px;
            border-radius: 50%;
        }

        .prof-info h1 {
            margin: 0 0 16px 0;
            font-size: 42px;
            color: var(--text-foreground);
        }

        .prof-stats {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 32px;
            margin-bottom: 48px;
        }

        .stat-box {
            background: var(--background-secondary);
            padding: 24px;
            border-radius: 12px;
        }

        .stat-label {
            font-size: 12px;
            color: var(--accent-secondary);
            text-transform: uppercase;
            margin-bottom: 8px;
        }

        .stat-value {
            font-size: 36px;
            color: var(--accent-primary);
            font-weight: 700;
        }

        .tests-list {
            margin-top: 32px;
        }

        .tests-list h2 {
            margin: 0 0 16px 0;
            color: var(--text-foreground);
        }

        .test-item {
            display: flex;
            justify-content: space-between;
            padding: 12px 0;
            border-bottom: 1px solid var(--background-secondary);
            color: var(--accent-secondary);
        }
    </style>
</head>
<body>
    <%- include("temp/nav") %>
    
    <main class="prof-cont">
        <div class="prof-header">
            <img src="<%= viewedPfp %>" class="prof-avatar" alt="Avatar">
            <div class="prof-info">
                <h1><%= viewedUsername %></h1>
                <p>Joined and competing</p>
            </div>
        </div>

        <div class="prof-stats">
            <div class="stat-box">
                <div class="stat-label">Best WPM</div>
                <div class="stat-value"><%= user.wpm %></div>
            </div>
            <div class="stat-box">
                <div class="stat-label">Total Score</div>
                <div class="stat-value"><%= user.score || 0 %></div>
            </div>
        </div>

        <% if (user.tests && user.tests.length > 0) { %>
            <div class="tests-list">
                <h2>Recent Tests</h2>
                <% user.tests.slice(-5).reverse().forEach(test => { %>
                    <div class="test-item">
                        <span><%= test.wpm %> WPM</span>
                        <span><%= test.acc %>% Accuracy</span>
                    </div>
                <% }); %>
            </div>
        <% } %>

        <% if (isOwn) { %>
            <a href="/" style="margin-top: 32px; display: inline-block; color: var(--accent-primary);">
                Back to typing test
            </a>
        <% } %>
    </main>
    
    <%- include("temp/foot") %>
</body>
</html>