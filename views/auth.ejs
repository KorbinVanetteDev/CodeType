<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("temp/head", { title: "CodeType | Sign in" }) %>
    
    <style>
        .auth-page {
            display: flex;
            align-items: center;
            justify-content: center;
            place-items: center;
            padding: 32px 64px 64px;
            flex: 1;
        }

        .auth-shell {
            width: min(100%, 920px);
            display: grid;
            grid-template-columns: 1.05fr 0.95fr;
            gap: 32px;
            align-items: stretch;
        }

        .auth-hero,
        .auth-panel {
            border-radius: 24px;
            background: linear-gradient(180deg, rgba(255,255,255,0.05), rgba(255,255,255,0.02));
            border: 1px solid rgba(120, 192, 255, 0.1);
        }

        .auth-hero {
            padding: 40px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            gap: 24px;
        }

        .auth-hero h1 {
            margin: 0;
            font-size: clamp(42px, 8vw, 72px);
            line-height: 0.95;
            color: var(--text-foreground);
        }

        .auth-hero p {
            margin: 0;
            max-width: 28ch;
            font-size: 18px;
            line-height: 1.6;
            color: var(--accent-secondary);
        }

        .auth-panel {
            padding: 32px;
            display: flex;
            flex-direction: column;
            gap: 24px;
            background: var(--background-primary);
        }

        .auth-tabs {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
            padding: 8px;
            border-radius: 18px;
            background: var(--background-secondary);
        }

        .auth-tab {
            border: none;
            border-radius: 14px;
            padding: 12px 16px;
            font: inherit;
            font-size: 16px;
            cursor: pointer;
            color: var(--accent-secondary);
            background: transparent;
            transition: 0.2s;
        }

        .auth-tab.is-active {
            background: var(--background-primary);
            color: var(--accent-primary);
            box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
        }

        .auth-form-stack {
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

        .auth-field {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .auth-field label {
            font-size: 14px;
            color: var(--accent-primary);
        }

        .auth-field input {
            width: 100%;
            padding: 14px 16px;
            border-radius: 14px;
            border: 1px solid var(--background-secondary);
            background: var(--background-primary);
            color: var(--accent-secondary);
            font: inherit;
            font-size: 16px;
        }

        .auth-field input:focus {
            border-color: var(--accent-primary);
            outline: none;
        }

        .auth-submit {
            margin-top: 4px;
            width: 100%;
            padding: 14px 18px;
            border-radius: 14px;
            border: none;
            background: var(--accent-primary);
            color: var(--background-primary);
            font: inherit;
            font-size: 16px;
            cursor: pointer;
            transition: 0.2s;
        }

        .auth-submit:hover {
            background: var(--accent-primary-hover);
        }

        .auth-error {
            padding: 12px 16px;
            border-radius: 14px;
            background: rgba(248, 81, 73, 0.12);
            color: #f85149;
            border: 1px solid rgba(248, 81, 73, 0.24);
            line-height: 1.5;
        }

        [data-panel] {
            display: none;
        }

        [data-panel].is-active {
            display: block;
        }

        @media (max-width: 900px) {
            .auth-shell {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <%- include("temp/nav") %>
    
    <main class="auth-page">
        <div class="auth-shell">
            <section class="auth-hero">
                <div>
                    <div class="logo" style="font-size: clamp(44px, 8vw, 84px); line-height: 0.95;">CodeType</div>
                </div>

                <div>
                    <h1>Type faster.<br>Keep score.</h1>
                    <p>Sign in to save your progress, or create a new account and start fresh. Everything stays local to this server.</p>
                </div>
            </section>

            <section class="auth-panel">
                <div class="auth-tabs">
                    <button class="auth-tab is-active" data-tab="login">Login</button>
                    <button class="auth-tab" data-tab="signup">Sign up</button>
                </div>

                <% if (error) { %>
                    <div class="auth-error"><%= error %></div>
                <% } %>

                <!-- Login Form -->
                <form method="POST" action="/login" data-panel="login" class="is-active">
                    <div class="auth-form-stack">
                        <div class="auth-field">
                            <label>Username</label>
                            <input type="text" name="username" required>
                        </div>
                        <div class="auth-field">
                            <label>Password</label>
                            <input type="password" name="password" required>
                        </div>
                        <button type="submit" class="auth-submit">Sign in</button>
                    </div>
                </form>

                <!-- Signup Form -->
                <form method="POST" action="/signup" data-panel="signup">
                    <div class="auth-form-stack">
                        <div class="auth-field">
                            <label>Username</label>
                            <input type="text" name="username" required>
                        </div>
                        <div class="auth-field">
                            <label>Password</label>
                            <input type="password" name="password" required>
                        </div>
                        <button type="submit" class="auth-submit">Create account</button>
                    </div>
                </form>
            </section>
        </div>
    </main>

    <%- include("temp/foot") %>

    <script>
        document.querySelectorAll("[data-tab]").forEach(tab => {
            tab.addEventListener("click", () => {
                const tabName = tab.getAttribute("data-tab");
                
                document.querySelectorAll(".auth-tab").forEach(t => 
                    t.classList.remove("is-active")
                );
                tab.classList.add("is-active");
                
                document.querySelectorAll("[data-panel]").forEach(panel => 
                    panel.classList.remove("is-active")
                );
                document.querySelector(`[data-panel="${tabName}"]`).classList.add("is-active");
            });
        });
    </script>
</body>
</html>